# 应用配置
APP_NAME=SuperBizAgent
DEBUG=True
HOST=0.0.0.0
PORT=9900

# OpenRouter 配置
OPENROUTER_API_KEY=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
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_MODEL=x-ai/grok-4.1-fast
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Milvus 配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TIMEOUT=1000000

# RAG 配置
RAG_TOP_K=5
RAG_MODEL=x-ai/grok-4.1-fast
RAG_RETRIEVE_TOOL_TIMEOUT_MS=300000
RAG_MILVUS_SEARCH_TIMEOUT_MS=180000
RAG_DEGRADE_GENERAL_ADVICE_ENABLED=true
RAG_SUMMARY_ENABLED=true
RAG_SUMMARY_TRIGGER_ROUNDS=10
RAG_SUMMARY_RECENT_ROUNDS_FOR_UPDATE=10
RAG_SUMMARY_MODEL=xiaomi/mimo-v2-flash
RAG_SUMMARY_MAX_CHARS=2000
# 每次知识库检索命中后，将召回全文追加写入下方 md（相对项目根）；含低置信命中（仍有 docs）
RAG_RECALL_DUMP_MD_ENABLED=true
RAG_RECALL_DUMP_MD_PATH=docx/rag_recall_runtime.md

# 混合检索：Milvus 向量 + Elasticsearch BM25，按排名加权融合（需 ES 可访问；未起 ES 时检索会降级为仅向量、索引仍写 Milvus）
RAG_HYBRID_ENABLED=false
ELASTICSEARCH_URL=https://localhost:9200
ELASTICSEARCH_INDEX=rag_chunks
ELASTICSEARCH_VERIFY_CERTS=true
# 自签名链不宜单独作 CA 时，用服务端证书 SHA256 指纹（python 见 scripts/test_elasticsearch_connection.py 内说明）
ELASTICSEARCH_CA_CERTS=
ELASTICSEARCH_SSL_ASSERT_FINGERPRINT=42:1B:7A:DE:A2:B3:B8:CE:78:80:1D:99:49:12:0F:D3:1A:4B:F1:80:E5:0E:3B:5C:9E:AA:63:66:A3:81:99:DD
# 若集群启用了 basic auth 再取消注释并填写：
ELASTICSEARCH_BASIC_AUTH_USER=elastic
ELASTICSEARCH_BASIC_AUTH_PASSWORD=l8gX+Dwp3OfiRJvRGMSD
RAG_HYBRID_VEC_TOP_K=10
RAG_HYBRID_BM25_TOP_K=10
RAG_HYBRID_RRF_K=60
RAG_HYBRID_VEC_WEIGHT=0.7
RAG_HYBRID_BM25_WEIGHT=0.3
RAG_ELASTICSEARCH_TIMEOUT_MS=12000

# 文档分块配置
CHUNK_MAX_SIZE=300
CHUNK_OVERLAP=50
# 层级分块（父/子 token，需 pip install tiktoken；开启后须全量重索引）：false=沿用 CHUNK_* 字符分块
RAG_HIERARCHICAL_CHUNKS_ENABLED=true
RAG_PARENT_CHUNK_TOKENS=512
RAG_PARENT_CHUNK_OVERLAP_TOKENS=128
RAG_CHILD_CHUNK_TOKENS=256
RAG_CHILD_CHUNK_OVERLAP_TOKENS=56
RAG_TOKENIZER_ENCODING=cl100k_base

# Redis 会话存储（RAG）
REDIS_URL=redis://localhost:6379/0
RAG_SESSION_TTL_SECONDS=604800
RAG_SESSION_MAX_EVENTS=50
RAG_SESSION_STORE_SYSTEM=False
PAPER_WORKFLOW_LIVE_TEST="1"
LONG_TERM_MEMORY_WRITE_ENABLED=true
CHAT_PAPER_ROUTE_ENABLED=true
PAPER_REPORT_STREAM_MAX_TOKENS=16384
RAG_MARKDOWN_SEMANTIC_CHUNK_ENABLED=true
RAG_REQUIRE_EXPLICIT_TENANT_FOR_UPLOAD=false